
{
  "hosting": {
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "*.log"
    ],
    "frameworksBackend": {
      "region": "us-central1"
    }
  },
  "firestore": {
    "rules": ".rules/firestore.rules"
  },
  "storage": {
    "rules": ".rules/storage.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ],
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ],
  "emulators": {
    "auth": {
      "host": "0.0.0.0",
      "port": 9099
    },
    "firestore": {
      "host": "0.0.0.0",
      "port": 8080
    },
    "storage": {
      "host": "0.0.0.0",
      "port": 9199
    },
    "hub": {
      "host": "0.0.0.0",
      "port": 4400
    },
    "ui": {
      "enabled": true
    },
    "functions": {
      "host": "0.0.0.0",
      "port": 5001
    },
    "logging": {
      "host": "0.0.0.0",
      "port": 4500
    },
    "singleProjectMode": true
  },
  "extensions": {}
}
